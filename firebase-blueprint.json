{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the QuickKart app",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "role": { "type": "string", "enum": ["customer", "admin", "delivery", "shop_owner"] },
        "walletBalance": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "role", "walletBalance", "createdAt"]
    },
    "Address": {
      "title": "Address",
      "description": "A delivery address for a user",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "label": { "type": "string" },
        "houseNo": { "type": "string" },
        "street": { "type": "string" },
        "city": { "type": "string" },
        "pincode": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "label", "houseNo", "street", "city", "pincode", "createdAt"]
    },
    "Order": {
      "title": "Order",
      "description": "An order placed by a customer",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "name": { "type": "string" },
              "price": { "type": "number" },
              "quantity": { "type": "number" }
            },
            "required": ["productId", "name", "price", "quantity"]
          }
        },
        "totalAmount": { "type": "number" },
        "deliveryFee": { "type": "number" },
        "paymentMethod": { "type": "string", "enum": ["COD", "UPI", "Wallet"] },
        "status": { "type": "string", "enum": ["pending", "accepted", "out_for_delivery", "delivered", "cancelled"] },
        "address": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "totalAmount", "deliveryFee", "paymentMethod", "status", "address", "createdAt"]
    },
    "WalletTransaction": {
      "title": "WalletTransaction",
      "description": "A transaction in the user's wallet",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["credit", "debit"] },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "amount", "type", "description", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "addresses/{addressId}": {
      "schema": { "$ref": "#/entities/Address" },
      "description": "User addresses"
    },
    "orders/{orderId}": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "Customer orders"
    },
    "wallet_transactions/{transactionId}": {
      "schema": { "$ref": "#/entities/WalletTransaction" },
      "description": "Wallet transactions"
    }
  }
}
